{
  "name": "cosmic",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others --names watch,serve \"bun run watch\" \"bun run dev:serve\"",
    "dev:serve": "bunx serve dist --listen 5050 --single",
    "build": "bun script/build.ts",
    "check": "bun run typecheck && bun run lint && bun run build",
    "watch": "chokidar \"src/**/*\" \"asset/**/*\" \"script/build.ts\" -c \"bun run build\" --initial",
    "lint": "bun eslint --max-warnings=0",
    "typecheck": "bun x tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@lonnycorp/htmlforge": "^0.1.1",
    "@stylistic/eslint-plugin-ts": "4.2.0",
    "@types/bun": "^1.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "8.26.1",
    "@typescript-eslint/parser": "8.26.1",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^10.0.3",
    "eslint": "9.22.0",
    "serve": "^14.2.6",
    "typescript": "^5.7.2"
  }
}
